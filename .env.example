# ─── Supabase ──────────────────────────────────────────────────────────────────
# Project URL: Settings → API → Project URL
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Anon (public) key: Settings → API → anon / public
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Admin panel ───────────────────────────────────────────────────────────────
# Password for /admin page (plain text, client-side check)
VITE_ADMIN_PASSWORD=your_secret_password

# ─── OpenAI (optional) ─────────────────────────────────────────────────────────
# When set, candidate answers are scored by gpt-4o-mini instead of keywords
# Leave empty to use keyword-only scoring (free, always works)
VITE_OPENAI_KEY=sk-...

# ─── Telegram (optional) ───────────────────────────────────────────────────────
# Bot token from @BotFather
VITE_TELEGRAM_BOT_TOKEN=1234567890:AAF...

# Default chat/channel ID for notifications (can be overridden per vacancy)
# Personal chat: open @userinfobot, copy your ID
# Group/channel: add bot as admin, send message, check updates API for chat_id
VITE_TELEGRAM_CHAT_ID=-1001234567890
